{
  "manifest_version": 3,
  "name": "GlowGuard",
  "version": "1.0.0",
  "description": "Soften harsh bright websites with a lightweight page dimmer.",
  "browser_specific_settings": {
    "gecko": {
      "id": "glowguard@bartecmunicipal.com",
      "strict_min_version": "109.0"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "background": {
    "scripts": ["background/service-worker.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/anti-flash.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content/overlay.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "permissions": ["storage", "alarms"],
  "commands": {
    "toggle-glowguard": {
      "suggested_key": { "default": "Alt+Shift+G" },
      "description": "Toggle GlowGuard on/off"
    },
    "dim-increase": {
      "suggested_key": { "default": "Alt+Shift+Up" },
      "description": "Increase dim level"
    },
    "dim-decrease": {
      "suggested_key": { "default": "Alt+Shift+Down" },
      "description": "Decrease dim level"
    }
  }
}
